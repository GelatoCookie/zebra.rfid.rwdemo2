<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/tag_row_card_bg"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/tagIndexText"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:background="#22007CB0"
        android:gravity="center"
        android:text="1"
        android:textColor="#FF00557A"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tagTypeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EPC"
            android:textColor="#99003C57"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tagEpcText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="monospace"
            android:text="300833B2DDD9014000000000"
            android:textColor="#FF112230"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tagCountBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/tag_count_badge_bg"
        android:text="x7"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>
