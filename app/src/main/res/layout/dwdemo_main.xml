<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/relativeLayout1"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color2" >

    <!-- Header -->

    <LinearLayout
        android:id="@+id/linearLayout1"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_layered_header"
        android:paddingBottom="8dp"
        android:paddingLeft="12dp"
        android:paddingTop="8dp" >

        <ImageView
            android:id="@+id/imageView1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/dwdemo2_content_description"
            android:src="@drawable/rfid_icon_s" />

        <TextView
            android:id="@+id/textView1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:paddingLeft="10dp"
            android:text="@string/dwdemo2_app_name"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- Soft scan buttons -->

    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_below="@+id/linearLayout1"
        android:background="@drawable/bg_layered_ssbutton"
        android:orientation="horizontal"
        android:padding="12dp" >

        <ImageButton
            android:id="@+id/barcodeScanButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/scan_trigger"
            android:contentDescription="Barcode Scan"
            android:scaleType="fitCenter"
            android:padding="10dp"
            android:src="@drawable/ic_barcode_trigger" />

        <ImageButton
            android:id="@+id/softscanbutton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/scan_trigger"
            android:contentDescription="RFID Scan"
            android:scaleType="fitCenter"
            android:padding="10dp"
            android:src="@drawable/ic_dw_cap_rfid" />

    </LinearLayout>

    <!-- Status Bar -->
    <LinearLayout
        android:id="@+id/statusLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/linearLayout2"
        android:orientation="horizontal"
        android:paddingLeft="19dp"
        android:paddingRight="19dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="#DDDDDD">

        <TextView
            android:id="@+id/scannerStatusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Scanner: UNKNOWN"
            android:textColor="#333333"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/rfidStatusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="RFID: UNKNOWN"
            android:textColor="#333333"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- results window -->

    <ScrollView
        android:id="@+id/scrollView1"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/statusLayout"
        android:layout_marginBottom="61dp"
        android:background="@drawable/bg_layered_textview"
        android:fillViewport="true"
        android:padding="0dp"
        android:scrollbars="vertical" >

        <TextView
            android:id="@+id/output_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="19dp"
            android:paddingRight="19dp"
            android:text="@string/dwdemo2_textview_text"
            android:textColor="?android:attr/textColorPrimaryInverse" />
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="18dp"
        android:layout_above="@+id/linearLayoutActionBar"
        android:background="@color/blue2" />

    <!-- Action bar -->

    <LinearLayout
        android:id="@+id/linearLayoutActionBar"
        android:layout_width="match_parent"
        android:layout_height="43dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_layered_actionbar"
        android:orientation="horizontal" >

        <ImageButton
            android:id="@+id/actionButton1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="2"
            android:layout_margin="8dp"
            android:background="@color/bg_color1"
            android:contentDescription="@string/dwdemo2_content_description"
            android:src="@drawable/clear_icon"
            android:tag="lumin_off" />

        <ImageButton
            android:id="@+id/actionButton2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="2"
            android:background="@color/bg_color1"
            android:contentDescription="@string/dwdemo2_content_description"
            android:tag="camera"
            android:visibility="invisible"/>

        <ImageButton
            android:id="@+id/actionButton3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="2"
            android:background="@color/bg_color1"
            android:contentDescription="@string/dwdemo2_content_description"
            android:tag="decode_center"
            android:visibility="invisible"/>

        <ImageButton
            android:id="@+id/actionButton4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="2"
            android:background="@color/bg_color1"
            android:contentDescription="@string/dwdemo2_content_description"
            android:src="@drawable/ic_menu_moreoverflow_normal_holo_dark" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_centerInParent="true"
        android:visibility="gone" />

</RelativeLayout>
